{
  "multipart": [

    {
      "apply": {
        "model": "notitlemod:block/energy_cable_center"
      }
    },

    {
      "when": {
        "north": true
      },
      "apply": {
        "model": "notitlemod:block/energy_cable_side"
      }
    },

    {
      "when": {
        "east": true
      },
      "apply": {
        "model": "notitlemod:block/energy_cable_side",
        "y": 90
      }
    },

    {
      "when": {
        "west": true
      },
      "apply": {
        "model": "notitlemod:block/energy_cable_side",
        "y": 270
      }
    },

    {
      "when": {
        "south": true
      },
      "apply": {
        "model": "notitlemod:block/energy_cable_side",
        "y": 180
      }
    },

    {
      "when": {
        "up": true
      },
      "apply": {
        "model": "notitlemod:block/energy_cable_side",
        "x": 270
      }
    },

    {
      "when": {
        "down": true
      },
      "apply": {
        "model": "notitlemod:block/energy_cable_side",
        "x": 90
      }
    }

  ]
}